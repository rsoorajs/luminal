            ?lda ?ldb ?c_row_stride ?ldd
            ?batch
            ?stride_a ?stride_b ?c_batch_stride ?stride_d
            ?a_dtype ?b_dtype ?c_dtype ?d_dtype
            ?compute_type ?scale_dtype
            ?alpha ?beta ?epilogue)
