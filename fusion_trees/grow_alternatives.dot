digraph grow_alternatives {
  rankdir=BT; nodesep=0.4; ranksep=0.5;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, penwidth=1.2];

  x [label="x", fillcolor="#f8f9fa"];
  FS [label="FS(x)", fillcolor="#d1e7dd"];

  // Inside-true chain (shared body)
  Sqrt_in [label="Sqrt_inside", fillcolor="#cfe2ff"];
  Sin_in  [label="Sin_inside",  fillcolor="#cfe2ff"];
  Recip_in [label="Recip_inside", fillcolor="#cfe2ff"];

  // Two FE alternatives
  subgraph cluster_fe1 {
    label="FE_12 e-class (region {Sqrt, Sin})"; style="dashed,filled"; fillcolor="#fff3cd";
    fontname="Helvetica"; fontsize=10;
    Sin_orig [label="Sin (false)", fillcolor="#cfe2ff"];
    FE_12    [label="FE_12",       fillcolor="#f8d7da"];
  }

  subgraph cluster_fe2 {
    label="FE_123 e-class (region {Sqrt, Sin, Recip})"; style="dashed,filled"; fillcolor="#fff3cd";
    fontname="Helvetica"; fontsize=10;
    Recip_orig [label="Recip (false)", fillcolor="#cfe2ff"];
    FE_123     [label="FE_123",         fillcolor="#f8d7da"];
  }

  Sqrt_orig [label="Sqrt (false)", fillcolor="#cfe2ff"];
  out [label="out", fillcolor="#f8f9fa"];

  x -> Sqrt_orig;
  x -> FS;
  FS -> Sqrt_in;
  Sqrt_in -> Sin_in;
  Sin_in  -> Recip_in;

  // FE_12's body refs
  Sin_in  -> FE_12;
  // FE_123's body refs
  Recip_in -> FE_123;

  // Original chain (still there, eclass-merged with FE forms)
  Sqrt_orig -> Sin_orig;
  Sin_orig  -> Recip_orig;
  Recip_orig -> out;

  labelloc=b;
  fontname="Helvetica"; fontsize=11;
  label="Trial 1 grow on Recip(Sin(Sqrt(x))). Two FE alternatives coexist:\nFE_12 represents {Sqrt,Sin} (output = Sin(Sqrt(x))).\nFE_123 represents {Sqrt,Sin,Recip} (output = Recip(Sin(Sqrt(x)))).\nDifferent VALUES, so not duplicates -- but cost-based extraction must choose.\nShared body: the Sqrt_inside/Sin_inside enodes are reused via e-class refs.";
}
