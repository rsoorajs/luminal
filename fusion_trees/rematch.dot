digraph rematch {
  rankdir=BT; nodesep=0.4; ranksep=0.5;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=12, penwidth=1.2];

  in     [label="in",      fillcolor="#f8f9fa"];
  U1     [label="U1",      fillcolor="#cfe2ff"];
  FS     [label="FS",      fillcolor="#d1e7dd"];
  U1_sep [label="U1_sep",  fillcolor="#cfe2ff"];
  U2_sep [label="U2_sep",  fillcolor="#cfe2ff"];

  subgraph cluster_merge {
    label="e-class: unary_2 = FE  (after iter 1 union)";
    style="dashed,filled"; fillcolor="#fff3cd";
    fontname="Helvetica"; fontsize=11;
    U2 [label="U2", fillcolor="#cfe2ff"];
    FE [label="FE", fillcolor="#f8d7da"];
  }

  out [label="out", fillcolor="#f8f9fa"];

  in -> U1     [color="#0066cc", penwidth=3];
  U1 -> U2     [color="#0066cc", penwidth=3];

  FS -> U1_sep [color="#dc3545", penwidth=3];
  U1_sep -> U2_sep [color="#dc3545", penwidth=3];

  in -> FS;
  U2_sep -> FE;
  U2 -> out;

  labelloc=b;
  fontname="Helvetica"; fontsize=12;
  label="BLUE = Match A: ?u2=U2 eclass, ?u1=U1 eclass, ?x=in (same as iter 1 -> hash-cons no-op)\nRED = Match B: ?u2=U2_sep, ?u1=U1_sep, ?x=FS (NEW match -> mints fresh FS(FS), U1_sep_2, U2_sep_2, FE_2)";
}
